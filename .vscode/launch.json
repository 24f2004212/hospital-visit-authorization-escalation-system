{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Backend (NestJS)",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}/backend",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "start:dev"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "Launch Frontend (Vite)",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}/frontend",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "dev"
            ],
            "console": "integratedTerminal"
        }
    ],
    "compounds": [
        {
            "name": "Launch Full Stack System",
            "configurations": [
                "Launch Backend (NestJS)",
                "Launch Frontend (Vite)"
            ]
        }
    ]
}
