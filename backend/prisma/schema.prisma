datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  password       String
  name           String
  role           String    @default("STUDENT") // STUDENT, WARDEN, GUARD, PROCTOR, PARENT, ADMIN
  phoneNumber    String?
  parentEmail    String?   
  parentPhone    String?   
  roomNumber     String?   
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  requestsMade   VisitRequest[]  @relation("StudentRequests")
  requestsApprov VisitRequest[]  @relation("WardenApprovals")
  guardAssigns   VisitRequest[]  @relation("GuardAssignments")
  feedbacks      Feedback[]
}

model VisitRequest {
  id             String      @id @default(uuid())
  studentId      String
  wardenId       String?
  guardId        String?
  status         String      @default("PENDING") // PENDING, APPROVED, REJECTED, ACTIVE, COMPLETED, ESCALATED
  reason         String
  urgency        String      @default("NORMAL") // NORMAL, EMERGENCY
  departureTime  DateTime?
  returnTime     DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  student        User        @relation("StudentRequests", fields: [studentId], references: [id])
  warden         User?       @relation("WardenApprovals", fields: [wardenId], references: [id])
  guard          User?       @relation("GuardAssignments", fields: [guardId], references: [id])
  
  feedbacks      Feedback[]
  escalations    EscalationLog[]
}

model Feedback {
  id             String      @id @default(uuid())
  visitRequestId String
  studentId      String
  rating         Int         
  comments       String?
  createdAt      DateTime    @default(now())

  visitRequest   VisitRequest @relation(fields: [visitRequestId], references: [id])
  student        User         @relation(fields: [studentId], references: [id])
}

model EscalationLog {
  id             String         @id @default(uuid())
  visitRequestId String
  type           String // DELAYED_APPROVAL, EMERGENCY_ALERT, OVERDUE_RETURN
  acknowledged   Boolean        @default(false)
  createdAt      DateTime       @default(now())

  visitRequest   VisitRequest   @relation(fields: [visitRequestId], references: [id])
}
